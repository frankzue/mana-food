# ─────────────────────────────────────────────────────────────
# Supabase — https://supabase.com/dashboard/project/_/settings/api
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# Solo del lado servidor (NO exponer al cliente, NO commitear)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta

# Email del admin (para seeds/bootstrap del panel)
ADMIN_EMAIL=admin@manafood.com

# ─────────────────────────────────────────────────────────────
# SEO / OpenGraph — usado en app/layout.tsx (metadataBase)
# En producción pon la URL pública (https://manafood.com o vercel.app)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
